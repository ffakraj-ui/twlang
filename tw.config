name: TWLang Site
pretty_urls: true
modular_pipeline: true
theme: system


server {
  external_packages [
    "firebase-admin",
    "firebase-admin/app",
    "firebase-admin/database",
    "google-auth-library",
    "google-play-scraper"
  ]
}

images {
  remote_patterns [
    { protocol: "https", hostname: "**" }
  ]
  unoptimized true
}

bundler {
  client_externals [
    "firebase-admin",
    "firebase-admin/app",
    "firebase-admin/database",
    "google-auth-library",
    "google-play-scraper"
  ]

  fallback {
    fs false
    net false
    tls false
    http false
    https false
    path false
    stream false
    crypto false
    os false
    zlib false
  }
}

headers {
  rule {
    source "/api/download/**"
    set "Cache-Control" "no-store, no-cache, private"
    set "Pragma" "no-cache"
  }

  rule {
    source "/api/admin/**"
    set "Cache-Control" "no-store, no-cache, private"
    set "Pragma" "no-cache"
  }

  rule {
    source "/admin/**"
    set "Cache-Control" "no-store, no-cache, private"
    set "Pragma" "no-cache"
  }

  rule {
    source "/static/**"
    set "Cache-Control" "public, max-age=31536000, immutable"
  }

  rule {
    source "/**"
    set "Cache-Control" "public, s-maxage=3600, stale-while-revalidate=86400"
  }
}

redirects {
  rule {
    source "/app/:slug"
    destination "/:slug"
    permanent true
  }

  rule {
    source "/private-team/:slug"
    destination "/team/:slug"
    permanent true
  }
}

rewrites {
  rule {
    source "/games"
    destination "/category/games"
  }

  rule {
    source "/popular"
    destination "/category/popular"
  }

  rule {
    source "/:slug"
    destination "/app/:slug"
  }
}
