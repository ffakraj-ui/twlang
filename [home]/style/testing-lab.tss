.testing-shell {
    display grid
    gap 28
    padding 48 20 72
    max-width 1200
    margin 0 auto
}

.hero-panel {
    display grid
    grid-template-columns minmax(0, 1.5fr) minmax(280px, 0.9fr)
    gap 22
    padding 28
    border-radius 30
    background linear-gradient(135deg, rgba(15, 23, 42, 0.98), rgba(30, 41, 59, 0.92))
    border 1px solid rgba(148, 163, 184, 0.18)
    box-shadow 0 24px 70px rgba(15, 23, 42, 0.22)
}

.hero-copy {
    display grid
    gap 14
}

.hero-copy h1 {
    margin 0
    font-size 46
    line-height 1.08
    color #f8fafc
}

.hero-copy p {
    margin 0
    color #cbd5e1
    line-height 1.75
    max-width 760
}

.eyebrow {
    display inline-flex
    width fit-content
    padding 7 13
    border-radius 999
    background rgba(96, 165, 250, 0.14)
    color #bfdbfe
    text-transform uppercase
    letter-spacing 0.08em
    font-size 12
}

.hero-pills {
    display flex
    flex-wrap wrap
    gap 10
}

.pill {
    display inline-flex
    align-items center
    padding 10 14
    border-radius 999
    background rgba(30, 41, 59, 0.88)
    border 1px solid rgba(148, 163, 184, 0.12)
    color #e2e8f0
    font-size 14
}

.hero-metrics {
    display grid
    gap 14
}

.metric-card {
    display grid
    gap 6
    padding 18 20
    border-radius 22
    background rgba(255, 255, 255, 0.04)
    border 1px solid rgba(148, 163, 184, 0.14)
    color #e2e8f0
}

.metric-card strong {
    font-size 28
    color #f8fafc
}

.section-block {
    display grid
    gap 18
}

.section-head {
    display grid
    gap 10
}

.section-head h2 {
    margin 0
    font-size 32
    color #0f172a
}

.section-head p {
    margin 0
    color #475569
    line-height 1.75
    max-width 820
}

.command-grid,
.fixture-grid,
.improvement-grid {
    display grid
    grid-template-columns repeat(2, minmax(0, 1fr))
    gap 18
}

.fixture-grid {
    grid-template-columns repeat(3, minmax(0, 1fr))
}

.command-card,
.fixture-card,
.improvement-card {
    display grid
    gap 12
    padding 22
    border-radius 24
    background #ffffff
    border 1px solid rgba(148, 163, 184, 0.2)
    box-shadow 0 16px 45px rgba(15, 23, 42, 0.06)
}

.command-card strong,
.fixture-card h3,
.improvement-card h3 {
    margin 0
    font-size 20
    color #0f172a
}

.command-card p,
.fixture-card p,
.improvement-card p {
    margin 0
    color #475569
    line-height 1.7
}

.command-card code {
    display block
    padding 14 16
    border-radius 16
    overflow auto
    background #0f172a
    color #e2e8f0
}

.fixture-code {
    margin 0
    padding 16
    border-radius 18
    overflow auto
    background #0f172a
    color #cbd5e1
}

@media (max-width: 1100px) {
    .hero-panel,
    .fixture-grid {
        grid-template-columns 1fr
    }
}

@media (max-width: 860px) {
    .testing-shell {
        padding 36 16 56
    }

    .hero-copy h1 {
        font-size 36
    }

    .section-head h2 {
        font-size 28
    }

    .command-grid,
    .improvement-grid {
        grid-template-columns 1fr
    }
}
