.site-header {
  position sticky
  top 0
  z-index 500
  width 100%
  background rgba(7,16,30,.84)
  backdrop-filter blur(20)
  border-bottom 1 solid rgba(148,163,184,.14)
  box-shadow 0 14 36 rgba(2,6,23,.16)
}

:root[data-theme="light"] .site-header {
  background rgba(255,255,255,.88)
  border-bottom 1 solid rgba(15,23,42,.08)
}

.header-shell {
  display flex
  align-items center
  justify-content space-between
  gap 22
  min-height 78
}

.brand-link {
  display inline-flex
  align-items center
  gap 14
  text-decoration none
  color inherit
}

.brand-mark {
  width 46
  height 46
  border-radius 16
  display inline-flex
  align-items center
  justify-content center
  background linear-gradient(135deg, #34d399 0%, #10b981 52%, #0891b2 100%)
  color white
  font-size 15
  font-weight 900
  letter-spacing .16em
  box-shadow 0 20 50 rgba(16,185,129,.24)
  flex-shrink 0
}

.brand-copy {
  display flex
  flex-direction column
  gap 2
}

.brand-copy strong {
  font-size 16
  line-height 1.1
}

.brand-copy small {
  font-size 12
  color var(--muted-color)
}

.desktop-nav {
  display flex
  align-items center
  gap 8
}

.nav-link {
  text-decoration none
  color var(--muted-color)
  font-weight 700
  font-size 14
  min-height 40
  padding 0 14
  border-radius 12
  display inline-flex
  align-items center
  justify-content center
  transition color .2s ease, background .2s ease, transform .2s ease
}

.nav-link:hover {
  background rgba(255,255,255,.06)
  color var(--text-color)
  transform translateY(-1)
}

:root[data-theme="light"] .nav-link:hover {
  background rgba(15,23,42,.04)
}

.nav-link-active {
  background rgba(16,185,129,.14)
  color #6ee7b7
}

:root[data-theme="light"] .nav-link-active {
  color #047857
}

.header-actions {
  display flex
  align-items center
  gap 12
}

.theme-toggle {
  min-height 44
  padding 0 16
  border-radius 12
  border 1 solid var(--border-color)
  background rgba(255,255,255,.05)
  color var(--text-color)
  font-weight 700
  cursor pointer
  transition transform .2s ease, border-color .2s ease, background .2s ease
}

:root[data-theme="light"] .theme-toggle {
  background rgba(15,23,42,.03)
}

.theme-toggle:hover {
  transform translateY(-1)
  border-color rgba(16,185,129,.34)
}

.header-cta {
  display inline-flex
  align-items center
  justify-content center
  min-height 46
  padding 0 20
  border-radius 12
  text-decoration none
  background linear-gradient(135deg, #0ea5e9 0%, #10b981 100%)
  color white
  font-weight 800
  box-shadow 0 18 45 rgba(14,165,233,.18)
}

@media (max-width:1024) {
  .desktop-nav {
    gap 16
  }
}

@media (max-width:768) {
  .header-shell {
    min-height 70
  }

  .desktop-nav {
    display none
  }

  .brand-copy small {
    display none
  }

  .theme-toggle {
    min-height 42
    padding 0 14
    font-size 13
    border-radius 10
  }

  .header-cta {
    display none
  }
}
