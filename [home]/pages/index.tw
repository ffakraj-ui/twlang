page {
    title "TWMODS | Premium APK Catalog"
    layout "main"
    render static
}

load "@./style/twmods-home.tss"

head {
    seo {
        description "TWMODS style premium APK catalog ka twlang homepage port with hero, hot apps, popular downloads, categories aur request CTA."
        og_title "TWMODS | Premium APK Catalog"
        og_description "Browse premium app cards, top picks, category blocks and mobile friendly homepage sections built on twlang."
    }
}

BODY {
    main {
        class "twmods-home"

        section {
            id "home"
            class "home-hero"

            div {
                class "container hero-shell"

                div {
                    class "hero-copy"

                    span "Premium APK hub" {
                        class "eyebrow"
                    }

                    h1 "Premium APK Downloads, Apps, Games and Mod Catalog."
                    p "Search aur browse premium-style APK listings with categories, ratings, version info, file size aur clean download-focused app cards. Homepage ko original app catalog flow ke closer redesign kiya gaya hai."

                    div {
                        class "hero-actions"

                        a "Search Now" {
                            href "/#search"
                            class "btn btn-primary"
                        }

                        a "Browse Apps" {
                            href "/#hot-apps"
                            class "btn btn-secondary"
                        }
                    }
                }

                div {
                    class "hero-surface"

                    article {
                        class "hero-card hero-card-large"

                        div {
                            class "hero-topline"

                            span "Trending now"
                            span {
                                class "live-dot"
                            }
                        }

                        h2 "Spotify Premium"
                        p {
                            class "card-copy"
                            text "Music streaming app card with premium catalog styling, highlighted rating, quick metadata aur bold CTA treatment."
                        }

                        div {
                            class "hero-pill-row"

                            span "4.9 rating" { class "pill" }
                            span "98 MB" { class "pill" }
                            span "Music" { class "pill" }
                        }
                    }
                }
            }
        }

        section {
            id "hot-apps"
            class "section"

            div {
                class "container"

                div {
                    class "section-head section-head-row"

                    div {
                        class "section-head-copy"

                        h2 "Hot Apps" {
                            class "section-title section-title-small"
                        }
                    }

                    a "More" {
                        href "/#latest"
                        class "section-more"
                    }
                }

                div {
                    class "catalog-grid"

                    article {
                        class "app-card"

                        div {
                            class "app-cover app-cover-emerald"

                            span "SP" {
                                class "app-icon"
                            }

                            span "Premium" {
                                class "app-badge"
                            }

                            span "Hot" {
                                class "app-hot"
                            }

                            span "98 MB" {
                                class "app-size"
                            }
                        }

                        div {
                            class "app-body"

                            h3 "Spotify Premium"
                            p {
                                class "app-subtitle"
                                text "Spotify Ltd"
                            }

                            p {
                                class "app-copy"
                                text "Premium music streaming card with strong visuals, trimmed description aur quick scan metadata."
                            }

                            div {
                                class "app-meta"

                                span "4.9 ★"
                                span "1.9M"
                                span "Music"
                            }
                        }
                    }

                    article {
                        class "app-card"

                        div {
                            class "app-cover app-cover-cyan"

                            span "CC" {
                                class "app-icon"
                            }

                            span "Editor" {
                                class "app-badge"
                            }

                            span "Hot" {
                                class "app-hot"
                            }

                            span "124 MB" {
                                class "app-size"
                            }
                        }

                        div {
                            class "app-body"

                            h3 "CapCut Pro"
                            p {
                                class "app-subtitle"
                                text "Bytedance"
                            }

                            p {
                                class "app-copy"
                                text "Video editing focused card with bright cover surface, compact copy aur premium utility feel."
                            }

                            div {
                                class "app-meta"

                                span "4.8 ★"
                                span "1.5M"
                                span "Video"
                            }
                        }
                    }

                    article {
                        class "app-card"

                        div {
                            class "app-cover app-cover-purple"

                            span "AM" {
                                class "app-icon"
                            }

                            span "Motion" {
                                class "app-badge"
                            }

                            span "New" {
                                class "app-hot app-hot-blue"
                            }

                            span "146 MB" {
                                class "app-size"
                            }
                        }

                        div {
                            class "app-body"

                            h3 "Alight Motion"
                            p {
                                class "app-subtitle"
                                text "Alight Creative"
                            }

                            p {
                                class "app-copy"
                                text "Motion design listing with vibrant gradient cover aur high-contrast app presentation."
                            }

                            div {
                                class "app-meta"

                                span "4.7 ★"
                                span "912K"
                                span "Design"
