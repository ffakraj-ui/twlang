                            p {
                                class "app-copy"
                                text "Utility app listing with tighter spacing, clear title hierarchy aur bold ranking surface."
                            }

                            div {
                                class "app-meta"

                                span "4.8 ★"
                                span "2.2M"
                                span "Tools"
                            }
                        }
                    }
                }

                a "More apps" {
                    href "/#latest"
                    class "section-button"
                }
            }
